# Backend Environment Template
# Copy to backend/.env and fill in values

AUTH_MODE=local
LOCAL_AUTH_TOKEN=your_token_here

DATABASE_URL=postgresql+psycopg://postgres:your_password@db:5432/mission_control
DB_AUTO_MIGRATE=true

CORS_ORIGINS=http://localhost:13000,http://your-tailscale-ip:13000
BASE_URL=http://your-tailscale-ip:18000
RQ_REDIS_URL=redis://redis:6379/0

LOG_LEVEL=INFO
REQUEST_LOG_SLOW_MS=1000
ENVIRONMENT=production