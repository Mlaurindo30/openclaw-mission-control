# Mission Control Environment Template
# Copy to .env and fill in values

# Ports (override defaults to avoid conflicts)
POSTGRES_PORT=15432
REDIS_PORT=16379
BACKEND_PORT=18000
FRONTEND_PORT=13000

# Database
POSTGRES_DB=mission_control
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# Auth
AUTH_MODE=local
LOCAL_AUTH_TOKEN=your_token_here

# URLs
CORS_ORIGINS=http://localhost:13000,http://your-tailscale-ip:13000
BASE_URL=http://your-tailscale-ip:18000
NEXT_PUBLIC_API_URL=http://your-tailscale-ip:18000
NEXT_PUBLIC_AUTH_MODE=local